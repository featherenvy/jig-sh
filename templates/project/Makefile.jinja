SHELL := /bin/bash

.DEFAULT_GOAL := help

CARGO ?= cargo
NODE ?= node
WEB_PACKAGE_MANAGER ?= <<[ web_package_manager ]>>
WEB_INSTALL_COMMAND ?= <<[ web_install_command ]>>
WEB_RUN_COMMAND ?= <<[ web_run_command ]>>
# This stamp only skips installs after a successful lockfile-respecting install;
# package/lockfile mtimes or missing node_modules force a fresh web-deps-install run.
WEB_DEPS_STAMP ?= .agent/.cache/web-deps-$(WEB_PACKAGE_MANAGER).stamp

DEFAULT_BRANCH ?= <<[ default_branch ]>>
JIG_VERSION ?= <<[ jig_version ]>>
RUST_CRATE_ROOTS := [% for root in rust_crate_roots %]<<[ root ]>>[% if not loop.last %] [% endif %][% endfor %]
[% if sqlx_enabled %]
RUST_MIGRATION_DIR := <<[ rust_migration_dir ]>>
[% endif %]

.PHONY: help bootstrap deps dev fmt-check clippy test-rust test-rust-locked test
[% if sqlx_enabled %]
.PHONY: sqlx-db-setup sqlx-check[% if schema_dump_enabled %] schema-check schema-dump[% endif %] migration-add contract-check
[% else %]
.PHONY: contract-check
[% endif %]
.PHONY: check-agent-map check-agent-guides check-rust-file-loc check-no-mod-rs[% if sqlx_enabled %] check-sqlx-unchecked-non-test[% endif %]
.PHONY: enforce-coverage web-deps web-deps-install typescript-lint typescript-typecheck typescript-build typescript-coverage ci ci-webapps
[% for app in frontend_apps %]
.PHONY: ci-webapp-<<[ app.name | replace('-', '_') ]>>
[% endfor %]

help: ## Show all available targets
	@echo "<<[ repo_name ]>> Makefile"
	@awk 'BEGIN {FS = ":.*##"} /^[A-Za-z0-9._-]+:.*##/ {printf "  %-28s %s\n", $$1, $$2}' $(MAKEFILE_LIST)

# Bootstrap uses a login shell so PATH includes tools installed by shell profile setup.
bootstrap: ## Initialize the local workspace
	@echo "If bootstrap cannot start jig, run: make deps"
	@bash -lc 'scripts/jig bootstrap'

deps: ## Install Rust and optional webapp dependencies
	$(CARGO) fetch
	$(MAKE) web-deps

web-deps: ## Install configured webapp dependencies
	@mkdir -p "$(dir $(WEB_DEPS_STAMP))"
[% if frontend_apps | length > 0 %]
	@if [ -f "$(WEB_DEPS_STAMP)" ]; then \
	  stale=0; missing=0; \
[% for app in frontend_apps -%]
[% if web_package_manager == "bun" -%]
	  for path in package.json bun.lock bun.lockb <<[ app.dir ]>>/package.json <<[ app.dir ]>>/bun.lock <<[ app.dir ]>>/bun.lockb; do \
	    if [ -e "$$path" ] && [ "$$path" -nt "$(WEB_DEPS_STAMP)" ]; then stale=1; fi; \
	  done; \
	  if [ -f package.json ] && { [ -f bun.lock ] || [ -f bun.lockb ]; }; then \
	    [ -d node_modules ] || missing=1; \
	  else \
	    { [ -f <<[ app.dir ]>>/bun.lock ] || [ -f <<[ app.dir ]>>/bun.lockb ]; } || missing=1; \
	    [ -d <<[ app.dir ]>>/node_modules ] || missing=1; \
	  fi; \
[% elif web_package_manager == "npm" -%]
	  for path in package.json package-lock.json <<[ app.dir ]>>/package.json <<[ app.dir ]>>/package-lock.json; do \
	    if [ -e "$$path" ] && [ "$$path" -nt "$(WEB_DEPS_STAMP)" ]; then stale=1; fi; \
	  done; \
	  if [ -f package.json ] && [ -f package-lock.json ]; then \
	    [ -d node_modules ] || missing=1; \
	  else \
	    [ -f <<[ app.dir ]>>/package-lock.json ] || missing=1; \
	    [ -d <<[ app.dir ]>>/node_modules ] || missing=1; \
	  fi; \
[% elif web_package_manager == "pnpm" -%]
	  for path in package.json pnpm-lock.yaml <<[ app.dir ]>>/package.json <<[ app.dir ]>>/pnpm-lock.yaml; do \
	    if [ -e "$$path" ] && [ "$$path" -nt "$(WEB_DEPS_STAMP)" ]; then stale=1; fi; \
	  done; \
	  if [ -f package.json ] && [ -f pnpm-lock.yaml ]; then \
	    [ -d node_modules ] || missing=1; \
	  else \
	    [ -f <<[ app.dir ]>>/pnpm-lock.yaml ] || missing=1; \
	    [ -d <<[ app.dir ]>>/node_modules ] || missing=1; \
	  fi; \
[% elif web_package_manager == "yarn" -%]
	  for path in package.json yarn.lock <<[ app.dir ]>>/package.json <<[ app.dir ]>>/yarn.lock; do \
	    if [ -e "$$path" ] && [ "$$path" -nt "$(WEB_DEPS_STAMP)" ]; then stale=1; fi; \
	  done; \
	  if [ -f package.json ] && [ -f yarn.lock ]; then \
	    [ -d node_modules ] || missing=1; \
	  else \
	    [ -f <<[ app.dir ]>>/yarn.lock ] || missing=1; \
	    [ -d <<[ app.dir ]>>/node_modules ] || missing=1; \
	  fi; \
[% endif -%]
	[% endfor -%]
		  if [ "$$stale" -eq 0 ] && [ "$$missing" -eq 0 ]; then \
		    :; \
		  else \
	    $(MAKE) web-deps-install; \
	  fi; \
	else \
	  $(MAKE) web-deps-install; \
	fi
[% else %]
	@echo "No web apps configured."
[% endif %]

web-deps-install: ## Install configured webapp dependencies without stamp checks
	@mkdir -p "$(dir $(WEB_DEPS_STAMP))"
[% if frontend_apps | length > 0 %]
[% for app in frontend_apps %]
[% if web_package_manager == "bun" %]
	@if [ -f package.json ] && { [ -f bun.lock ] || [ -f bun.lockb ]; }; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% elif web_package_manager == "npm" %]
	@if [ -f package.json ] && [ -f package-lock.json ]; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% elif web_package_manager == "pnpm" %]
	@if [ -f package.json ] && [ -f pnpm-lock.yaml ]; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% elif web_package_manager == "yarn" %]
	@if [ -f package.json ] && [ -f yarn.lock ]; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% endif %]
[% endfor %]
	@touch "$(WEB_DEPS_STAMP)"
[% else %]
	@echo "No web apps configured."
[% endif %]

typescript-lint: web-deps ## Run configured TypeScript lint checks
[% if frontend_apps | length > 0 %]
[% for app in frontend_apps %]
	$(NODE) scripts/check-webapp-scripts.mjs <<[ app.dir ]>> lint
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) lint
[% endfor %]
[% else %]
	@echo "No web apps configured."
[% endif %]

typescript-typecheck: web-deps ## Run configured TypeScript type checks
[% if frontend_apps | length > 0 %]
[% for app in frontend_apps %]
	$(NODE) scripts/check-webapp-scripts.mjs <<[ app.dir ]>> typecheck
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) typecheck
[% endfor %]
[% else %]
	@echo "No web apps configured."
[% endif %]

typescript-build: web-deps ## Run configured TypeScript bundle builds
[% if frontend_apps | length > 0 %]
[% for app in frontend_apps %]
	$(NODE) scripts/check-webapp-scripts.mjs <<[ app.dir ]>> build:bundle
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) build:bundle
[% endfor %]
[% else %]
	@echo "No web apps configured."
[% endif %]

typescript-coverage: web-deps ## Run configured TypeScript coverage checks
[% if frontend_apps | length > 0 %]
[% for app in frontend_apps %]
	$(NODE) scripts/check-webapp-scripts.mjs <<[ app.dir ]>> test:coverage
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) test:coverage
	$(MAKE) enforce-coverage COVERAGE_DIR=<<[ app.dir ]>>/coverage COVERAGE_THRESHOLD=<<[ app.coverage_threshold ]>>
[% endfor %]
[% else %]
	@echo "No web apps configured."
[% endif %]

dev: ## Run the configured dev command
	scripts/jig dev

fmt-check: ## Check Rust formatting
	scripts/jig check fmt

clippy: ## Run clippy for the Rust workspace
	scripts/jig check clippy

test-rust: ## Run Rust workspace tests
	scripts/jig check test

test-rust-locked: ## Run Rust workspace tests with --locked
	scripts/jig check test-locked

test: test-rust ## Run the default backend test suite

[% if sqlx_enabled %]
sqlx-db-setup: ## Reset the SQLx check database and apply migrations
	SQLX_OFFLINE=false $(CARGO) sqlx database reset -y --source "$(RUST_MIGRATION_DIR)"

sqlx-check: ## Verify committed SQLx metadata is current
	scripts/jig check sqlx

[% if schema_dump_enabled %]
schema-check: ## Verify schema docs are current when enabled
	scripts/jig check schema

schema-dump: ## Regenerate schema docs when enabled
	scripts/jig schema-dump
[% endif %]

migration-add: ## Add a forward-only migration (pass NAME=<migration_name>)
	@if [ -z "$(NAME)" ]; then \
	  echo "NAME is required. Example: make migration-add NAME=create_users"; \
	  exit 1; \
	fi
	scripts/jig migration-add "$(NAME)"
[% endif %]

contract-check: ## Verify the generated jig contract and runtime wiring
	scripts/jig check contract

check-agent-map: ## Verify agent-map.md coverage and links
	scripts/jig check agent-map

check-agent-guides: ## Verify crate-level AGENTS.md guides
	scripts/jig check agent-guides

check-rust-file-loc: ## Enforce Rust file-size policy against the default branch
	@set -euo pipefail; \
	if git rev-parse --verify origin/$(DEFAULT_BRANCH) >/dev/null 2>&1; then \
	  base_ref="$$(git merge-base HEAD origin/$(DEFAULT_BRANCH))"; \
	elif git rev-parse --verify HEAD^ >/dev/null 2>&1; then \
	  base_ref="HEAD^"; \
	else \
	  base_ref="4b825dc642cb6eb9a060e54bf8d69288fbee4904"; \
	fi; \
	echo "Using Rust LOC base ref: $$base_ref"; \
	scripts/jig check rust-file-loc --changed-against "$$base_ref"

check-no-mod-rs: ## Fail if disallowed mod.rs files exist under configured crate roots
	scripts/jig check no-mod-rs

[% if sqlx_enabled %]
check-sqlx-unchecked-non-test: ## Verify non-test SQLx queries use compile-time checked macros
	scripts/jig check sqlx-unchecked-non-test
[% endif %]

enforce-coverage: ## Enforce a coverage threshold from COVERAGE_THRESHOLD against COVERAGE_DIR
	@COVERAGE_DIR="$(COVERAGE_DIR)" COVERAGE_THRESHOLD="$(COVERAGE_THRESHOLD)" $(NODE) scripts/enforce-coverage.js

[% if frontend_apps | length > 0 %]
[% for app in frontend_apps %]
ci-webapp-<<[ app.name | replace('-', '_') ]>>: ## Run CI-style checks for <<[ app.name ]>>
	$(NODE) scripts/check-webapp-scripts.mjs <<[ app.dir ]>> lint typecheck build:bundle test:coverage
[% if web_package_manager == "bun" %]
	@if [ -f package.json ] && { [ -f bun.lock ] || [ -f bun.lockb ]; }; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% elif web_package_manager == "npm" %]
	@if [ -f package.json ] && [ -f package-lock.json ]; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% elif web_package_manager == "pnpm" %]
	@if [ -f package.json ] && [ -f pnpm-lock.yaml ]; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% elif web_package_manager == "yarn" %]
	@if [ -f package.json ] && [ -f yarn.lock ]; then \
	  $(WEB_INSTALL_COMMAND); \
	else \
	  cd <<[ app.dir ]>> && $(WEB_INSTALL_COMMAND); \
	fi
[% endif %]
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) lint
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) typecheck
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) build:bundle
	cd <<[ app.dir ]>> && $(WEB_RUN_COMMAND) test:coverage
	$(MAKE) enforce-coverage COVERAGE_DIR=<<[ app.dir ]>>/coverage COVERAGE_THRESHOLD=<<[ app.coverage_threshold ]>>

[% endfor %]
ci-webapps:[% for app in frontend_apps %] ci-webapp-<<[ app.name | replace('-', '_') ]>>[% endfor %] ## Run CI-style checks for configured web apps
[% else %]
ci-webapps: ## No configured web apps
	@echo "No web apps configured."
[% endif %]

ci: fmt-check clippy test-rust-locked contract-check check-rust-file-loc check-no-mod-rs check-agent-map check-agent-guides[% if sqlx_enabled %] check-sqlx-unchecked-non-test sqlx-check[% if schema_dump_enabled %] schema-check[% endif %][% endif %] ci-webapps ## Run the standard CI validation set
