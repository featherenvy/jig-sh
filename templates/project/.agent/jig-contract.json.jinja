{
  "contract_version": 2,
  "tool_namespace": "jig",
  "jig_version": "<<[ jig_version ]>>",
  "required_commands": [
    "bootstrap_command",
    "rust_fmt_check_command",
    "rust_clippy_command",
    "rust_test_command",
    "rust_test_locked_command",
[% if sqlx_enabled %]
    "sqlx_check_command",
    "migration_add_command",
[% endif %]
[% if sqlx_enabled and schema_dump_enabled %]
    "schema_check_command",
    "schema_dump_command",
[% endif %]
    "contract_check_command"
  ],
  "tools": [
    {
      "name": "jig.bootstrap",
      "kind": "command",
      "description": "Run the configured project bootstrap command.",
      "command": "bootstrap_command"
    },
    {
      "name": "jig.fmt_check",
      "kind": "command",
      "description": "Run the configured format check command.",
      "command": "rust_fmt_check_command"
    },
    {
      "name": "jig.clippy",
      "kind": "command",
      "description": "Run the configured clippy command.",
      "command": "rust_clippy_command"
    },
    {
      "name": "jig.test",
      "kind": "command",
      "description": "Run the configured default test command.",
      "command": "rust_test_command"
    },
    {
      "name": "jig.test_locked",
      "kind": "command",
      "description": "Run the configured locked test command.",
      "command": "rust_test_locked_command"
    },
[% if sqlx_enabled %]
[% if schema_dump_enabled %]
    {
      "name": "jig.schema_check",
      "kind": "command",
      "description": "Run the configured schema check command.",
      "command": "schema_check_command"
    },
    {
      "name": "jig.schema_dump",
      "kind": "command",
      "description": "Run the configured schema dump command.",
      "command": "schema_dump_command"
    },
[% endif %]
    {
      "name": "jig.sqlx_check",
      "kind": "command",
      "description": "Run the configured SQLx check command.",
      "command": "sqlx_check_command"
    },
    {
      "name": "jig.migration_add",
      "kind": "command",
      "description": "Run the configured migration creation command.",
      "command": "migration_add_command"
    },
[% endif %]
    {
      "name": "jig.contract_check",
      "kind": "command",
      "description": "Run the configured Jig contract check command.",
      "command": "contract_check_command"
    }
[% if makefile_enabled %]
    ,
    {
      "name": "jig.run_target",
      "kind": "make",
      "description": "Run an arbitrary make target by name.",
      "target": null
    }
[% endif %]
  ]
}
